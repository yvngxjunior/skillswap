    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
